<?xml version="1.0"?>
<robot name="drone">

  <!-- Materials -->
  <material name="electric_blue">
    <color rgba="0.05 0.45 1.0 1.0"/>
  </material>
  <material name="neon_cyan">
    <color rgba="0.0 0.95 0.95 1.0"/>
  </material>
  <material name="neon_orange">
    <color rgba="1.0 0.45 0.0 1.0"/>
  </material>
  <material name="neon_green">
    <color rgba="0.1 0.95 0.2 1.0"/>
  </material>
  <material name="neon_yellow">
    <color rgba="1.0 0.9 0.0 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.4 0.2 0.04"/>
      </geometry>
      <material name="electric_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.4 0.04 0.04"/>
      </geometry>
    </collision>
    <!--<inertial>
       <mass value="0.3"/>
       <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
     </inertial>-->
  </link>

  <link name="FL">
    <visual>
      <origin xyz="0.16 0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
      <material name="neon_cyan"/>
    </visual>
    <collision>
      <origin xyz="0.16 0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <link name="FR">
    <visual>
      <origin xyz="0.16 -0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
      <material name="neon_orange"/>
    </visual>
    <collision>
      <origin xyz="0.16 -0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <link name="BL">
    <visual>
      <origin xyz="-0.09 0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
      <material name="neon_green"/>
    </visual>
    <collision>
      <origin xyz="-0.09 0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <link name="BR">
    <visual>
      <origin xyz="-0.09 -0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
      <material name="neon_yellow"/>
    </visual>
    <collision>
      <origin xyz="-0.09 -0.13 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.03" radius="0.13"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <joint name="base_to_FL" type="fixed">
    <parent link="base_link"/>
    <child link="FL"/>
  </joint>
  <joint name="base_to_FR" type="fixed">
    <parent link="base_link"/>
    <child link="FR"/>
  </joint>
  <joint name="base_to_BL" type="fixed">
    <parent link="base_link"/>
    <child link="BL"/>
  </joint>
  <joint name="base_to_BR" type="fixed">
    <parent link="base_link"/>
    <child link="BR"/>
  </joint>

  <!-- Gazebo materials -->
  <gazebo reference="base_link">
    <material>Gazebo/BlueGlow</material>
    <turnGravityOff>true</turnGravityOff>
  </gazebo>
  <gazebo reference="FL">
    <material>Gazebo/Cyan</material>
  </gazebo>
  <gazebo reference="FR">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="BL">
    <material>Gazebo/Green</material>
  </gazebo>
  <gazebo reference="BR">
    <material>Gazebo/Yellow</material>
  </gazebo>

</robot>
